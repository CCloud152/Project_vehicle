# ==========================================
# 车辆识别系统 - 环境配置
# 复制自 .env.example，根据实际环境修改
# ==========================================

# ==========================================
# 基础配置
# ==========================================
ENV=development
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=True

# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL=sqlite:///car_recognition.db
CELERY_BROKER_TYPE=sqlalchemy

# Redis配置（当CELERY_BROKER_TYPE=redis时使用）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==========================================
# AI模型服务配置
# ==========================================
MODEL_SERVICE_TYPE=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:8b
OLLAMA_TIMEOUT=300

# vLLM配置（如果使用vLLM）
# VLLM_HOST=http://localhost:8000
# VLLM_MODEL=qwen3-vl:8b
# VLLM_TIMEOUT=300

# ==========================================
# 文件存储配置
# ==========================================
STORAGE_TYPE=local
UPLOAD_FOLDER=uploads

# ==========================================
# Celery Worker配置
# ==========================================
WORKER_CONCURRENCY=1
LOG_LEVEL=DEBUG