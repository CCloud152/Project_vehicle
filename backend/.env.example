# ==========================================
# 车辆识别系统 - 环境配置模板
# 复制为 .env 文件并修改配置
# ==========================================

# ==========================================
# 基础配置
# ==========================================
# 环境模式: development 或 production
ENV=development

# Flask密钥（生产环境请修改为随机字符串）
SECRET_KEY=your-secret-key-here

# 调试模式（生产环境设为False）
DEBUG=True

# ==========================================
# 数据库配置
# ==========================================
# 使用SQLite（<10并发场景足够）
DATABASE_URL=sqlite:///car_recognition.db

# Celery Broker配置
# 可选: sqlalchemy (SQLite) 或 redis
CELERY_BROKER_TYPE=sqlalchemy

# Redis配置（当CELERY_BROKER_TYPE=redis时使用）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==========================================
# AI模型服务配置
# ==========================================
# 模型服务类型: ollama 或 vllm
MODEL_SERVICE_TYPE=ollama

# Ollama配置
# 本地部署: http://localhost:11434
# 云端部署: http://your-cloud-gpu-ip:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:8b
OLLAMA_TIMEOUT=300

# vLLM配置（如果使用vLLM）
VLLM_HOST=http://localhost:8000
VLLM_MODEL=qwen3-vl:8b
VLLM_TIMEOUT=300

# ==========================================
# 文件存储配置
# ==========================================
# 存储类型: local 或 s3 或 oss
STORAGE_TYPE=local

# 本地存储路径
UPLOAD_FOLDER=uploads

# S3配置（当STORAGE_TYPE=s3时使用）
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.amazonaws.com

# 阿里云OSS配置（当STORAGE_TYPE=oss时使用）
OSS_BUCKET=your-bucket-name
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ==========================================
# Celery Worker配置
# ==========================================
# Worker并发数（云端GPU通常设为1）
WORKER_CONCURRENCY=1

# 日志级别
LOG_LEVEL=INFO